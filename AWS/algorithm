-sudo nano /etc/nginx/sites-available/hms:paste this on the file but do not copy blindly:
server {
    listen 80;
    server_name 51.21.5.98;

    location = /favicon.ico {
        access_log off;
        log_not_found off;
    }

    # STATIC FILES (correct way)
    location /static/ {
        alias /home/ubuntu/hms-project/hms/staticfiles/;
    }

    # MEDIA FILES (if you use uploads)
    location /media/ {
        alias /home/ubuntu/hms-project/hms/media/;
    }

    location / {
        include proxy_params;
        proxy_pass http://unix:/home/ubuntu/hms-project/hms/gunicorn.sock;
    }
}

